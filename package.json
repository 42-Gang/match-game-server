{
  "name": "match-game-server",
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "npm run build:ts && dotenv -e .env -- node dist/src/main.js",
    "prod": "node dist/src/main.js",
    "dev": "dotenv -e .env.dev -- tsx watch src/main.ts",
    "run:ts": "tsx src/main.ts",
    "watch:ts": "tsx watch src/main.ts",
    "build:ts": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint ./src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init && prisma generate",
    "prisma:reset": "prisma migrate reset --force && prisma generate",
    "prisma:deploy": "prisma migrate deploy && prisma generate",
    "prisma:seed": "prisma db seed",
    "tree": "tree -I 'node_modules|dist|prisma|coverage|.git'"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "kafkajs": "^2.2.4",
    "redis": "^5.1.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/config-array": "^0.19.2",
    "@eslint/js": "^9.23.0",
    "@eslint/object-schema": "^2.1.6",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@vitest/coverage-v8": "^3.0.9",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.2.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.3",
    "fastify-tsconfig": "^3.0.0",
    "glob": "^11.0.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.9",
    "vitest-mock-extended": "^3.0.1"
  }
}
